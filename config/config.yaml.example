# config.yaml 예시 (실제 키/계좌번호는 config/config.yaml에 넣고 .git에 올리지 마세요)
# 이 파일을 복사해 config.yaml 로 저장한 뒤 값을 채우면 앱 실행 가능합니다.
# 복사: config/config.yaml.example -> config/config.yaml

# 실전 투자
api_key: "실전_API_KEY"
api_secret_key: "실전_시크릿"
stock_account_number: "실전_계좌번호"
url: "https://openapi.koreainvestment.com:9443"
websocket_url: "ws://ops.koreainvestment.com:21000"

# 모의 투자
paper_api_key: "모의_API_KEY"
paper_api_secret_key: "모의_시크릿"
paper_stock_account_number: "모의_계좌번호"
paper_url: "https://openapivts.koreainvestment.com:29443"
paper_websocket_url: "ws://ops.koreainvestment.com:31000"

# 실전/모의 선택 (true: 모의, false: 실전)
is_paper_trading: true

# 선택
htsid: ""
custtype: "P"
market_open_time: "09:00"
market_close_time: "15:40"
market_timezone: "Asia/Seoul"

# 계좌 보호용 Kill Switch
kill_switch:
  enabled: false
  notify_only: false                       # true이면 트립/알림/상태 기록만 수행하고 주문·전략은 차단하지 않음.
  daily_loss_threshold_won: 1000000      # 일손실 한도 (원). 초과 시 트립.
  daily_loss_threshold_pct: 5.0          # 일손실 한도 (%). 원화/% 중 하나라도 초과하면 트립.
  max_consecutive_losses: 3              # 연속 손실 한도. 초과 시 트립.
  max_consecutive_api_errors: 10         # 연속 API 오류 한도. 초과 시 트립.
  abnormal_fill_deviation_pct: 3.0       # 체결가가 주문가 대비 이 비율 이상 이탈 시 트립.
  state_file_path: "data/kill_switch_state.json"

# 주문 직전 Risk Gate (hard block)
risk_gate:
  enabled: true
  max_order_amount_won: 10000000
  max_daily_order_amount_won: 50000000
  max_pending_orders: 10
  max_total_exposure_pct: 95.0
  # is_paper_trading=false (실전) 일 때 자동 적용되는 canary overlay.
  # 검증 전 운영을 보호하기 위해 더 보수적인 한도를 강제한다. paper 동작은 영향 없음.
  # production 등급으로 풀고 싶을 때만 명시값을 주면 yaml 값이 우선한다.
  real_mode_overrides:
    max_total_exposure_pct: 30.0
    max_pending_orders: 5

# Order policy / liquidity guard before order submit
order_policy:
  enabled: true
  order_book_checks_enabled: true
  security_status_checks_enabled: true
  security_status_fail_policy: "block"
  trade_flow_checks_enabled: true
  trade_flow_fail_policy: "block"
  trade_flow_cache_ttl_sec: 3.0
  trade_flow_sample_window_sec: 60
  max_last_trade_age_sec: 60.0
  min_recent_trade_count: 1
  min_trade_value_per_min_won: 0
  min_execution_strength_pct: 0.0
  max_market_slippage_pct: 1.0
  max_spread_pct: 1.0
  min_trading_value_won: 100000000
  min_market_cap_won: 100000000000
  max_top_of_book_participation_pct: 100.0
  block_managed_issue: true
  block_investment_warning: true
  block_investment_caution: false
  blocked_stock_status_codes: ["51", "52", "53", "58"]
  quote_fail_policy: "block"
  # 실전 모드에서 fail-close 지향 canary overlay.
  real_mode_overrides:
    allow_market_buy: false
    max_market_slippage_pct: 0.5
    max_spread_pct: 0.5
    max_top_of_book_participation_pct: 10.0

# 주문 제출 재시도 정책
order_execution:
  order_max_retries: 3
  order_retry_delay_sec: 3

# 데이터 품질 게이트 (주문 전 차단 + 실시간/REST sanity check)
data_quality:
  enabled: true
  # 운영 기본값. 유동성이 낮은 종목의 정상 tick 공백을 고려해 5초보다 완화한다.
  max_tick_age_sec: 30.0
  max_rest_age_sec: 10.0
  max_price_jump_pct: 15.0
  # 모의투자는 지연/공백이 더 잦을 수 있어 실전보다 완화한다.
  paper_max_tick_age_sec: 60.0
  paper_max_rest_age_sec: 15.0
  paper_max_price_jump_pct: 20.0
  # 실전은 주문 전 차단 기준을 더 보수적으로 둔다.
  real_max_tick_age_sec: 30.0
  real_max_rest_age_sec: 10.0
  real_max_price_jump_pct: 15.0
  block_on_stale_price: true
  block_on_invalid_api_response: true
  alert_cooldown_sec: 60.0

# 외부 알림 채널
notifications:
  telegram:
    enabled: true
    # Telegram으로 즉시 발송할 이벤트 레벨. 여기에 없는 info 이벤트는 웹 SSE/히스토리에만 남긴다.
    route_levels:
      SYSTEM: ["error", "critical"]
      TRADE: ["warning", "error", "critical"]
      BACKGROUND: ["error", "critical"]
      STRATEGY: ["warning", "error", "critical"]
      API: ["error", "critical"]

# 체결 품질 리포트 경고 기준 (사후 평가용, 자동 비활성화는 기본 OFF)
execution_quality_report:
  enabled: true
  min_sample_count: 3
  liquidity_control_effective_date: null   # YYYYMMDD. 설정 시 4-2 Liquidity Control 적용 전/후 라벨 분리
  warn_avg_slippage_pct: 0.5
  warn_p95_slippage_pct: 1.0
  warn_avg_first_fill_latency_sec: 30.0
  warn_incomplete_fill_ratio_pct: 20.0
  warn_avg_unfilled_ratio_pct: 20.0
  warn_avg_order_age_sec: 120.0
  candidate_avg_slippage_pct: 1.0
  candidate_p95_slippage_pct: 2.0
  candidate_avg_first_fill_latency_sec: 90.0
  candidate_incomplete_fill_ratio_pct: 40.0
  candidate_avg_unfilled_ratio_pct: 40.0
  candidate_avg_order_age_sec: 300.0
  auto_disable_enabled: false

# 전략별 최근 거래 성과 저하 감지 (사후 평가용, 1차는 soft alert만)
strategy_performance_degradation:
  window_size: 20
  min_live_trades: 10
  min_baseline_trades: 10
  capital_base_won: null          # live/backtest가 같은 분모 정의를 쓸 때만 설정
  warn_win_rate_drop_pctp: 15.0
  warn_avg_return_drop_pctp: 1.0
  warn_profit_factor_below: 1.0
  critical_consecutive_losses: 5
  critical_mdd_ratio_multiplier: 2.0

# 전략 수익성 gate / 포트폴리오 상관 리포트 (사후 평가용)
strategy_profitability_gate:
  strategy_correlation_min_overlap: 5
  strategy_correlation_warning_threshold: 0.8
  strategy_correlation_metric: "net_return"
  market_beta_min_overlap: 5
  market_beta_warning_threshold: 1.5
  market_beta_metric: "net_return"
  market_beta_benchmark_metric: "market_return"
  daily_entry_warning_threshold: 5
  opening_entry_warning_threshold: 3
  closing_entry_warning_threshold: 3
  consecutive_loss_warning_threshold: 3

# 포지션 사이징 (Fixed Fractional / Penbold 식)
position_sizing:
  enabled: true
  per_trade_risk_pct: 1.5          # 1주당 리스크 한도 (총자산 대비 %)
  max_per_position_pct: 10.0       # 단일 종목 비중 상한 (%)
  default_stop_loss_pct: -5.0      # 시그널 미전달 시 폴백 손절폭 (음수)
  atr_period: 14
  atr_multiplier: 2.0
  min_stop_distance_pct: 1.0       # 산식 보호용 최소 손절 거리 (%)
  snapshot_ttl_sec: 60             # 잔고 스냅샷 안전망 TTL (초)
  # 실전 모드에서 자동 적용되는 canary overlay.
  real_mode_overrides:
    per_trade_risk_pct: 0.5
    max_per_position_pct: 3.0
